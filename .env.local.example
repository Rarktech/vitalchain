# Sui zkLogin — Google OAuth Client ID
# 1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized origins: http://localhost:3000 + your Vercel domain
# 4. Add authorized redirect URIs: http://localhost:3000/app
# 5. Copy Client ID below
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Sui zkLogin prover service (free Mysten Labs testnet prover)
NEXT_PUBLIC_PROVER_URL=https://prover-dev.mystenlabs.com/v1

# Sui network (testnet | mainnet | devnet)
NEXT_PUBLIC_SUI_NETWORK=testnet

# Arkiv server wallet — EVM private key used server-side to sign entity writes on Braga
# Fund the derived address at https://braga.hoodi.arkiv.network/faucet/
# NEVER prefix with NEXT_PUBLIC_ — must remain server-side only
ARKIV_SERVER_PVK=0xYOUR_EVM_PRIVATE_KEY_HERE

# Gemini AI — used by /api/ai for health data analysis
# Get a free key at https://aistudio.google.com/app/apikey (no billing required on free tier)
# NEVER prefix with NEXT_PUBLIC_ — must remain server-side only
GEMINI_API_KEY=your-gemini-api-key-here
