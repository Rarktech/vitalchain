# Sui zkLogin — Google OAuth Client ID
# 1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized origins: http://localhost:3000 + your Vercel domain
# 4. Copy Client ID below
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Sui zkLogin prover service (free Mysten Labs testnet prover)
NEXT_PUBLIC_PROVER_URL=https://prover-dev.mystenlabs.com/v1

# Sui network (testnet | mainnet | devnet)
NEXT_PUBLIC_SUI_NETWORK=testnet
